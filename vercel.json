{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/github-read",  "dest": "/api/github-read.js"  },
    { "src": "/api/github-write", "dest": "/api/github-write.js" },
    { "src": "/api/github-debug", "dest": "/api/github-debug.js" },
    { "src": "/admin",            "dest": "/public/admin/index.html" },
    { "src": "/admin/",           "dest": "/public/admin/index.html" },
    { "src": "/css/(.*)",         "dest": "/public/css/$1"   },
    { "src": "/js/(.*)",          "dest": "/public/js/$1"    },
    { "src": "/images/(.*)",      "dest": "/public/images/$1" },
    { "src": "/404",              "dest": "/public/404.html" },
    { "src": "/",                 "dest": "/public/index.html" },
    { "src": "/(.*)",             "dest": "/public/$1",
      "continue": true },
    { "src": "/(.*)",             "dest": "/public/404.html",
      "status": 404 }
  ]
}
